# ============================================================================
# NGROK CONFIGURATION EXAMPLE - FRONTEND
# ============================================================================
#
# Replace "YOUR-NGROK-URL" with your actual Ngrok URL
# Example: 1234567890ab.ngrok-free.app
#
# Make sure both backend .env and frontend .env use the SAME Ngrok URL!
#

# ============================================================================
# API Configuration
# ============================================================================
# This is the URL your frontend uses to call the API
# Must match the backend APP_URL
#
VITE_API_URL=https://YOUR-NGROK-URL.ngrok-free.app

# ============================================================================
# WebSocket / Broadcasting Configuration
# ============================================================================
# These settings connect your frontend to Reverb/Pusher for real-time updates
#
VITE_REVERB_HOST=YOUR-NGROK-URL.ngrok-free.app
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_APP_KEY=dvezjwkd3tdmeki2s3nl

# ============================================================================
# App Configuration
# ============================================================================
VITE_APP_NAME="Attendance Management System"
VITE_APP_VERSION=1.0.0
VITE_PWA_ENABLED=true

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
#
# 1. Both Backend & Frontend MUST use HTTPS (if Ngrok provides HTTPS)
# 2. Both MUST use the SAME domain (your Ngrok URL)
# 3. WebSocket port MUST be 443 for HTTPS
# 4. Clear browser cache/localStorage if having issues
#
