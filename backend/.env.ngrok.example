# ============================================================================
# NGROK CONFIGURATION EXAMPLE - Full PWA Support
# ============================================================================
#
# This file shows how to configure your .env for Ngrok tunneling with
# complete PWA (Progressive Web App) support including HTTPS, manifest,
# service workers, and offline functionality.
#
# IMPORTANT: Replace "YOUR-NGROK-URL" with your actual Ngrok URL
# Example: 1234567890ab.ngrok-free.app
#
# How to get your Ngrok URL:
# 1. Start Laravel:    php artisan serve --host=0.0.0.0 --port=8000
# 2. Start Ngrok:      ngrok http 8000
# 3. Copy the URL from "Forwarding: https://..." line
#

APP_NAME="Attendance Management System"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:your-generated-key-here

# ============================================================================
# CRITICAL: Set this to your Ngrok HTTPS URL for PWA
# ============================================================================
# PWA requires HTTPS! Ngrok automatically provides HTTPS forwarding
# Format: https://YOUR-NGROK-URL.ngrok-free.app
#
APP_URL=https://YOUR-NGROK-URL.ngrok-free.app

# ============================================================================
# SANCTUM - API Authentication & Secure Cookies
# ============================================================================
# List all domains that are allowed to make API requests
# MUST include your Ngrok domain for CORS to work!
#
SANCTUM_STATEFUL_DOMAINS=localhost:8000,127.0.0.1:8000,localhost:5173,127.0.0.1:5173,YOUR-NGROK-URL.ngrok-free.app

# For production/HTTPS, set these to secure mode
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ============================================================================
# DATABASE
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=attendance_apps
DB_USERNAME=root
DB_PASSWORD=roots

# ============================================================================
# BROADCASTING - WebSocket/Pusher Configuration (PWA Real-time Features)
# ============================================================================
BROADCAST_CONNECTION=reverb

# Reverb (Laravel native WebSockets) - for notifications & real-time updates
REVERB_APP_ID=12345
REVERB_APP_KEY=dvezjwkd3tdmeki2s3nl
REVERB_APP_SECRET=your-app-secret

# IMPORTANT: Set these to your Ngrok domain for broadcasting to work via HTTPS
# This enables real-time notifications in your PWA
REVERB_HOST=YOUR-NGROK-URL.ngrok-free.app
REVERB_PORT=443
REVERB_SCHEME=https

# For frontend to connect to WebSocket (must match backend)
VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=${REVERB_HOST}
VITE_REVERB_PORT=${REVERB_PORT}
VITE_REVERB_SCHEME=${REVERB_SCHEME}

# ============================================================================
# CACHE & SESSION for Distributed Systems
# ============================================================================
CACHE_STORE=database
SESSION_DRIVER=database

# ============================================================================
# TRUST PROXIES - Important for Ngrok/Production
# ============================================================================
# Ngrok acts as a reverse proxy. This tells Laravel to trust proxy headers
# Set to * to trust all proxies (only for ngrok/testing)
# For production, specify specific proxy IPs
#
TRUSTED_PROXIES=*

# ============================================================================
# APP MAINTENANCE
# ============================================================================
APP_MAINTENANCE_DRIVER=file

# ============================================================================
# LOGGING
# ============================================================================
LOG_CHANNEL=stack
LOG_LEVEL=warning

# ============================================================================
# PWA FRONTEND URL (for CORS if frontend on different domain)
# ============================================================================
FRONTEND_URL=https://YOUR-NGROK-URL-FRONTEND.ngrok-free.app
REVERB_PORT=443
REVERB_SCHEME=https

# For development, allow self-signed certificates (if using HTTPS)
BROADCAST_VERIFY_SSL=true

# ============================================================================
# SESSION & COOKIES
# ============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Set to your Ngrok domain so cookies are sent to correct origin
SESSION_DOMAIN=YOUR-NGROK-URL.ngrok-free.app
SESSION_PATH=/
SESSION_SECURE_COOKIES=true  # HTTPS only

# ============================================================================
# LOGGING & CACHE
# ============================================================================
LOG_CHANNEL=stack
CACHE_STORE=database
QUEUE_CONNECTION=database

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Laravel's CORS is configured in config/cors.php
# It automatically accepts *.ngrok.io and *.ngrok-free.app domains
# No changes needed here!

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Make sure your frontend .env also uses the Ngrok URL:
#
# VITE_API_URL=https://YOUR-NGROK-URL.ngrok-free.app
# VITE_REVERB_HOST=YOUR-NGROK-URL.ngrok-free.app
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME=https

# ============================================================================
# OPTIONAL: Other Services
# ============================================================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

VITE_APP_NAME="${APP_NAME}"
